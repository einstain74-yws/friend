# --- GitHub Pages (워크플로 기본: VITE_DATA_BACKEND=auto) ---
# Firebase + Supabase 시크릿을 모두 넣으면 앱은 Firestore에 먼저 저장합니다.
# Supabase만 쓰려면: VITE_DATA_BACKEND=supabase (Firebase env는 무시됨)
VITE_DATA_BACKEND=auto

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# (선택) Supabase CLI — `npm run supabase -- login` 후 또는 Personal Access Token
# SUPABASE_ACCESS_TOKEN=sbp_...

# (선택) 터미널에서 npm run db:apply 로 Supabase 마이그레이션 시만
# DATABASE_URL=postgresql://postgres.[ref]:비밀번호@...pooler.supabase.com:6543/postgres

# (선택) Express 로컬 API — 클라우드보다 최우선
# VITE_API_BASE_URL=http://localhost:8787

# GitHub Pages 프로젝트 페이지 (저장소 이름이 friend일 때) — 빌드/배포 시
# VITE_BASE_PATH=/friend/
