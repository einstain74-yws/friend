# --- 데이터 백엔드: Supabase(Postgres)만 사용할 때 권장 설정 ---
# VITE_DATA_BACKEND=supabase 이면 Firestore 데이터 경로는 사용하지 않습니다 (src/config.js).
# 로컬·CI·배포를 맞출 때: VITE_DATA_BACKEND=auto 이고 VITE_FIREBASE_* 가 있으면 Firestore가
# Supabase보다 우선됩니다. GitHub Pages 기본 워크플로(.github/workflows/deploy-gh-pages.yml)는
# VITE_DATA_BACKEND=supabase 로 고정되어 있으니, 로컬도 supabase로 맞추면 노트북·웹·Supabase DB가
# 한곳을 가리킵니다. Firebase env는 이 경우 비워 두면 됩니다.
VITE_DATA_BACKEND=supabase

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# (선택) Firestore를 쓰는 레거시 배포만: VITE_DATA_BACKEND=auto 또는 firestore + 아래 전부
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# ...

# (선택) Supabase CLI — `npm run supabase -- login` 후 또는 Personal Access Token
# SUPABASE_ACCESS_TOKEN=sbp_...

# (선택) 터미널에서 npm run db:apply 로 Supabase 마이그레이션 시만
# DATABASE_URL=postgresql://postgres.[ref]:비밀번호@...pooler.supabase.com:6543/postgres

# (선택) Express 로컬 API — 클라우드보다 최우선
# VITE_API_BASE_URL=http://localhost:8787

# GitHub Pages 프로젝트 페이지 (저장소 이름이 friend일 때) — 워크플로에서 VITE_BASE_PATH=/friend/ 로 전달
# 배포된 사이트가 “클라우드 없음(로컬 전용 동작)처럼” 보이면, Actions에 아래 2개 시크릿이 비어
# 있지 않은지 확인: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY
