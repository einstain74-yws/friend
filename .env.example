# --- Supabase 전용(권장, GitHub Pages와 동일) ---
# Firebase env가 있어도 DB는 Postgres만 씁니다.
VITE_DATA_BACKEND=supabase
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# (선택) `auto` = Firestore+Supabase 둘 다 넣으면 Firestore 우선 / `firestore` = Firestore만
# VITE_DATA_BACKEND=auto

# Firestore 쓸 때만 (VITE_DATA_BACKEND 가 auto 또는 firestore 일 때)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# (선택) 터미널에서 npm run db:apply 로 Supabase 마이그레이션 시만
# DATABASE_URL=postgresql://postgres.[ref]:비밀번호@...pooler.supabase.com:6543/postgres

# (선택) Express 로컬 API — 클라우드보다 최우선
# VITE_API_BASE_URL=http://localhost:8787

# GitHub Pages 프로젝트 페이지 (저장소 이름이 friend일 때) — 빌드/배포 시
# VITE_BASE_PATH=/friend/
